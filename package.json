{
  "name": "keycloak-login-email-svelte",
  "description": "Keycloakify Svelte Starter with Better Svelte Email and Shadcn UI components for complete Login and Email theme customization without PatternFly.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Prajwalg19/keycloak-login-email-svelte.git"
  },
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "keycloakify sync-extensions",
    "dev": "vite",
    "build": "vite build",
    "build-keycloak-theme": "keycloakify sync-extensions && npm run build && keycloakify build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write '**/*.{ts,html,json,md,svelte}'",
    "lint": "yarn format && eslint . --fix",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@fontsource-variable/roboto": "^5.2.10",
    "@internationalized/date": "^3.12.0",
    "@keycloakify/email-native": "~260007.0.0",
    "@keycloakify/svelte": "^0.2.9",
    "@lucide/svelte": "^1.23.0",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/addon-svelte-csf": "5.0.10",
    "@storybook/svelte": "^10.0.7",
    "@storybook/svelte-vite": "^10.0.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.17",
    "@tsconfig/svelte": "^5.0.6",
    "@types/eslint": "^9.6.1",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "esbuild-svelte": "^0.9.5",
    "eslint": "9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.0.7",
    "eslint-plugin-svelte": "^3.13.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "formsnap": "^2.0.1",
    "globals": "^16.5.0",
    "jsrepo": "^3.7.0",
    "keycloakify": "^11.15.3",
    "keycloakify-emails": "^3.4.0",
    "npm-check-updates": "^19.1.2",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn-svelte": "^1.3.0",
    "storybook": "^10.0.7",
    "svelte": "^5.43.7",
    "svelte-check": "^4.3.4",
    "sveltekit-superforms": "^2.30.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "@better-svelte-email/components": "^2.1.1",
    "@better-svelte-email/server": "^2.1.1"
  }
}
